---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Steps from '~/components/widgets/Steps.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Personal Homepage Demo',
};
---

<Layout metadata={metadata}>
  <Fragment slot="announcement"></Fragment>
  <Fragment slot="header">
    <Header
      links={[
        { text: 'Home', href: '#' },
        { text: 'About', href: '/#about' },
        { text: 'Blog', href: '/blog' },
        { text: 'Github', href: 'https://github.com/Astol' },
      ]}
      actions={[
        {
          text: 'Contact me',
          href: getPermalink('/contact#form'),
        },
      ]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <Hero
    id="hero"
    title="Alexander Stolpe"
    tagline="Small notes. Sturdy systems."
    actions={[{ variant: 'primary', text: 'Contact me', href: getPermalink('/contact#form') }]}
  >
    <Fragment slot="subtitle">
      Software Developer, DevOps Engineer, and curious builder. <br />
      I help make software behave, guide it safely out into the world, and keep it on the right path once it gets there.
      Most of my days are spent in the .NET world, where I'm fond of sturdy systems, thoughtful architecture, and useful
      notes.
    </Fragment>
  </Hero>

  <!-- Content Widget **************** -->

  <Content
    id="about"
    columns={3}
    items={[
      {
        icon: 'tabler:brand-linkedin',
        callToAction: {
          target: '_blank',
          text: 'LinkedIn',
          href: 'https://www.linkedin.com/in/alexander-stolpe-65136a13a',
        },
      },
      {
        icon: 'tabler:brand-github',
        callToAction: {
          target: '_blank',
          text: 'GitHub',
          href: 'https://github.com/Astol',
        },
      },
    ]}
    image={{
      src: '~/assets/images/me.webp',
      alt: 'Colorful Image',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">About me</h2>
      <p>
        Welcome, traveler. I'm a software developer and DevOps engineer with a fondness for building things properly,
        deploying them safely, and learning something new along the way.
      </p>
      <br />
      <p>
        Most of my professional work lives in the .NET world, where I enjoy backend development, architecture, and the
        craft of writing code that is performant, maintainable, and pleasant to return to later.
      </p>
      <br />
      <p>
        Quiet Archive is my little corner for projects, notes, experiments, and lessons gathered from the road. If
        you’re curious to follow the trail, you can find me here:
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    id="resume"
    title="Work experience"
    items={[
      {
        title:
          'Software Developer / DevOps<br /> <span class="font-normal">Swedish government agency — consultant through Consid AB</span> <br /> <span class="text-sm font-normal">2019 - Present</span>',
        description: `Long-term consultant assignment for a Swedish government agency with business-critical administrative systems and high requirements for security, reliability, and traceability. The assignment has involved several roles over time, covering system development, DevOps, application operations, and team coordination.
        <br /><br />
        <b>System Developer<br>
        2019-ongoing</b>
        <br />
        Part of a cross-functional Scrum team responsible for developing and maintaining administrative systems used in business-critical case handling. The work covered the full technical stack, including database, backend, integrations, and frontend across systems of different generations.
        Worked with technologies and concepts such as Entity Framework, REST APIs, WCF, NHibernate, and event-based communication. The assignment also included test automation through unit tests, integration tests, and end-to-end tests.
        Contributed to internal knowledge sharing through training sessions and recurring developer forums focused on code quality, teamwork, policies, and continuous improvement.
        <br /><br />
        <b>DevOps / Application Operations<br />
        2023-ongoing</b>
        <br />
        Part of the DevOps group with responsibility for application servers, including installation, operation, monitoring, and troubleshooting in a Windows-based environment. The work included CI/CD pipelines in Azure DevOps, as well as log and alarm management using Grafana and Seq.
        Also involved in production-related installations and incident handling, sometimes outside regular working hours. The group worked proactively with monitoring, maintenance, and continuous improvements through regular coordination, shared responsibility, and rotating environment watch.
        <br /><br />
        <b>Acting Scrum Master / Team Coordinator<br />
        March 2025-December 2025</b>
        <br />
        Temporarily took on the role of Scrum Master during a colleague's parental leave, with responsibility for planning, coordination, and representing the team in workplace forums. Supported the team by facilitating Scrum ceremonies, removing obstacles, onboarding and coaching team members, and helping maintain a steady delivery flow.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Software Developer <br /> <span class="font-normal">Briljant Eknomisystem AB</span> <br /> <span class="text-sm font-normal">2017 - 2019</span>',
        description: `Briljant develops an economic system used by small and medium-sized enterprises. <br />
        Responsible for assigned functionality, covering design, development, support, and user training. Main focus was a mobile-adapted PWA for time reporting, developed largely in Angular. A key challenge was ensuring full offline support with reliable synchronization once the device came back online. Also worked on functionality for automatically importing invoices from email, as well as smaller bug fixes and miscellaneous development tasks.`,
        icon: 'tabler:briefcase',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    id="resume"
    title="Education"
    items={[
      {
        title: `Bachelor's Programme in Programming <br /> <span class="font-normal">Linköping University</span> <br /> <span class="text-sm font-normal">2014 - 2017</span>`,
        icon: 'tabler:school',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Skills"
    subtitle="A selection of technologies, tools, and methods I have worked with professionally across software development, testing, DevOps, and operations."
    columns={3}
    defaultIcon="tabler:point-filled"
    items={[
      {
        title: 'Backend',
        description:
          'C#, .NET, .NET Core, ASP.NET, Razor Pages, OData, Entity Framework, Fluent NHibernate, VB.NET, REST APIs, WCF, event-based communication',
      },
      {
        title: 'Frontend',
        description:
          'Angular, Blazor Server, Blazor WebAssembly, JavaScript, TypeScript, HTML, CSS, Sass, Bootstrap, PWA, Service Workers, responsive design',
      },
      {
        title: 'Database',
        description:
          'SQL, Microsoft SQL Server, SQL Server Management Studio, database design, query optimization, data modeling',
      },
      {
        title: 'DevOps & Operations',
        description:
          'Azure DevOps, CI/CD, Microsoft Azure, IIS, Windows Server, Linux, PowerShell, Grafana, Seq, log management, monitoring, incident handling',
      },
      {
        title: 'Testing & Automation',
        description:
          'Playwright, Reqnroll, SpecFlow, FluentAssertions, test automation, unit testing, integration testing, end-to-end testing',
      },
      {
        title: 'Tools',
        description: 'Git, SVN, Visual Studio, JetBrains Rider, ReSharper, Webpack',
      },
      {
        title: 'Ways of Working',
        description:
          'Scrum, Agile development, DevOps, cross-functional teams, technical responsibility, support, troubleshooting, onboarding, user training, internal knowledge sharing, developer forums, continuous improvement',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Want to talk code?"
    subtitle="Open to conversations about software development, collaboration, and interesting technical challenges."
    actions={[
      {
        variant: 'primary',
        text: 'Contact me',
        href: getPermalink('/contact#form'),
      },
    ]}
  />

  <!-- BlogLatestPost Widget **************** -->

  <BlogLatestPosts
    id="blog"
    title="Recent entries from the archive"
    information={`Dive into my collection of technical notes, field reports, and lessons worth keeping. Gathered from the many paths between code, databases, and deployments.`}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </BlogLatestPosts>
</Layout>
