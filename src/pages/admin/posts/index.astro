---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Blog Posts',
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <a
          href="/admin"
          class="inline-flex items-center text-sm font-medium text-primary-600 hover:text-primary-700 hover:underline dark:text-primary-400 dark:hover:text-primary-300"
        >
          ← Back to Admin
        </a>

        <h1 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 dark:text-white">Blog Posts</h1>

        <p class="mt-2 max-w-2xl text-sm text-gray-600 dark:text-gray-400">
          Manage your posts here. Changes are saved to Supabase, and the public site updates after the next rebuild.
        </p>
      </div>

      <a
        href="/admin/posts/new"
        class="inline-flex items-center justify-center rounded-xl bg-primary-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 dark:focus:ring-offset-gray-950"
      >
        New post
      </a>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-900">
      <div class="flex items-center justify-between border-b border-gray-200 px-5 py-4 dark:border-gray-700">
        <div>
          <h2 class="text-base font-semibold text-gray-900 dark:text-white">All posts</h2>

          <p id="status" class="mt-1 text-sm text-gray-500 dark:text-gray-400">Loading posts…</p>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table id="posts-table" class="w-full min-w-[760px] text-left text-sm" hidden>
          <thead class="bg-gray-50 text-xs uppercase tracking-wide text-gray-500 dark:bg-gray-800 dark:text-gray-400">
            <tr>
              <th class="px-5 py-3 font-semibold">Title</th>
              <th class="px-5 py-3 font-semibold">Slug</th>
              <th class="px-5 py-3 font-semibold">Status</th>
              <th class="px-5 py-3 font-semibold">Updated</th>
              <th class="px-5 py-3 text-right font-semibold">Actions</th>
            </tr>
          </thead>

          <tbody id="posts-body" class="divide-y divide-gray-200 dark:divide-gray-700"></tbody>
        </table>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { getSupabaseBrowserClient } from '~/lib/supabase/browser';

  const supabase = getSupabaseBrowserClient();

  let isLoading = false;

  function getElements() {
    const status = document.querySelector('#status');
    const table = document.querySelector('#posts-table');
    const tbody = document.querySelector('#posts-body');

    if (!status || !table || !tbody) {
      return null;
    }

    return { status, table, tbody };
  }

  function initPostsPage() {
    const elements = getElements();

    if (!elements) {
      return;
    }

    const { tbody } = elements;

    if (tbody.dataset.deleteHandlerAttached !== 'true') {
      tbody.addEventListener('click', handleDeleteClick);
      tbody.dataset.deleteHandlerAttached = 'true';
    }

    void loadPosts();
  }

  async function loadPosts() {
    if (isLoading) {
      return;
    }

    const elements = getElements();

    if (!elements) {
      return;
    }

    const { status, table, tbody } = elements;

    isLoading = true;
    status.textContent = 'Loading posts…';
    table.hidden = true;

    try {
      const { data: posts, error } = await supabase
        .from('posts')
        .select('id,title,slug,status,updated_at,published_at')
        .order('updated_at', { ascending: false });

      if (error) {
        status.textContent = `Could not load posts: ${error.message}`;
        return;
      }

      tbody.innerHTML = '';

      for (const post of posts ?? []) {
        const row = document.createElement('tr');

        row.className = 'hover:bg-gray-50 dark:hover:bg-gray-800/60';

        row.innerHTML = `
        <td class="px-5 py-4 align-top">
          <div class="font-medium text-gray-900 dark:text-white">
            ${escapeHtml(post.title ?? '(Untitled)')}
          </div>
        </td>

        <td class="px-5 py-4 align-top text-gray-500 dark:text-gray-400">
          <span class="font-mono text-xs">
            ${escapeHtml(post.slug ?? '')}
          </span>
        </td>

        <td class="px-5 py-4 align-top">
          <span class="inline-flex rounded-full px-2.5 py-1 text-xs font-medium">
            ${escapeHtml(post.status ?? 'unknown')}
          </span>
        </td>

        <td class="px-5 py-4 align-top text-gray-500 dark:text-gray-400">
          ${formatDate(post.updated_at ?? post.published_at)}
        </td>

        <td class="px-5 py-4 align-top text-right">
          <a
            href="/admin/posts/edit?id=${encodeURIComponent(post.id)}"
            class="mr-3 text-sm font-medium text-primary-600 hover:underline dark:text-primary-400"
          >
            Edit
          </a>

          <button
            type="button"
            data-delete-id="${encodeURIComponent(post.id)}"
            class="text-sm font-medium text-red-600 hover:underline dark:text-red-400"
          >
            Delete
          </button>
        </td>
        `;

        tbody.appendChild(row);
      }

      table.hidden = false;
      status.textContent = `${posts?.length ?? 0} posts found.`;
    } catch (error) {
      status.textContent = error instanceof Error ? `Could not load posts: ${error.message}` : 'Could not load posts.';
    } finally {
      isLoading = false;
    }
  }

  async function handleDeleteClick(event) {
    const elements = getElements();

    if (!elements) {
      return;
    }

    const { status } = elements;

    const target = event.target;

    if (!(target instanceof Element)) {
      return;
    }

    const button = target.closest('button[data-delete-id]');

    if (!(button instanceof HTMLButtonElement)) {
      return;
    }

    const id = decodeURIComponent(button.dataset.deleteId ?? '');

    if (!id) {
      return;
    }

    const shouldDelete = confirm(
      'Are you sure you want to delete this post? The public site will update after the next rebuild.'
    );

    if (!shouldDelete) {
      return;
    }

    button.disabled = true;
    status.textContent = 'Deleting post…';

    const { error } = await supabase.from('posts').delete().eq('id', id);

    if (error) {
      button.disabled = false;
      status.textContent = `Could not delete post: ${error.message}`;
      return;
    }

    status.textContent = 'Post deleted from Supabase. Public site updates after rebuild.';
    await loadPosts();
  }

  function formatDate(value) {
    if (!value) {
      return '';
    }

    return new Date(value).toLocaleString();
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  // Normal initial load.
  initPostsPage();

  // Astro client-side navigation / ViewTransitions.
  document.addEventListener('astro:page-load', initPostsPage);

  // Browser back/forward cache restore.
  window.addEventListener('pageshow', () => {
    initPostsPage();
  });
</script>
